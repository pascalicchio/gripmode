<header style="position:sticky;top:0;z-index:20;background:#ffffffe8;backdrop-filter:blur(10px);border-bottom:1px solid #e5e7eb">
  <div class="gm-container" style="height:78px;display:flex;align-items:center;justify-content:space-between">
    <a href="/" style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1.18rem;letter-spacing:.2px;text-decoration:none;color:#0f1115">GRIPMODE</a>

