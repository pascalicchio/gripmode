  </div>

  <style>
    @media (max-width: 980px) {
      .desktop-nav { display: none !important; }
      .mobile-toggle { display: block !important; }
      .mobile-menu.open { display: block !important; }
    }
    .dropdown.open .dropdown-menu { display: block !important; }
  </style>
</header>
