    <nav style="display:flex;align-items:center;gap:32px" class="desktop-nav">
      <div style="position:relative" class="dropdown">
        <button style="background:none;border:none;font:inherit;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:4px;color:#0f1115;padding:0" onclick="this.parentElement.classList.toggle('open')">
          Features <i data-lucide="chevron-down" style="width:16px;height:16px"></i>
        </button>
        <div class="dropdown-menu" style="display:none;position:absolute;top:100%;left:-16px;padding-top:12px;z-index:30">
          <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:8px;min-width:280px;box-shadow:0 12px 40px rgba(0,0,0,0.12)">
            <a href="/features/" style="display:block;padding:10px 14px;border-radius:8px;text-decoration:none;color:#0f1115;font-weight:600;font-size:.95rem" onmouseover="this.style.background='#f7f8fa'" onmouseout="this.style.background='transparent'">All Features</a>
            <a href="/features/crm-leads/" style="display:block;padding:10px 14px;border-radius:8px;text-decoration:none;color:#0f1115;font-size:.9rem" onmouseover="this.style.background='#f7f8fa'" onmouseout="this.style.background='transparent'">CRM & Lead Management</a>
            <a href="/features/scheduling/" style="display:block;padding:10px 14px;border-radius:8px;text-decoration:none;color:#0f1115;font-size:.9rem" onmouseover="this.style.background='#f7f8fa'" onmouseout="this.style.background='transparent'">Class Scheduling</a>
            <a href="/features/payroll/" style="display:block;padding:10px 14px;border-radius:8px;text-decoration:none;color:#0f1115;font-size:.9rem" onmouseover="this.style.background='#f7f8fa'" onmouseout="this.style.background='transparent'">Automated Payroll</a>
            <a href="/features/analytics/" style="display:block;padding:10px 14px;border-radius:8px;text-decoration:none;color:#0f1115;font-size:.9rem" onmouseover="this.style.background='#f7f8fa'" onmouseout="this.style.background='transparent'">Analytics Dashboard</a>
            <a href="/features/member-management/" style="display:block;padding:10px 14px;border-radius:8px;text-decoration:none;color:#0f1115;font-size:.9rem" onmouseover="this.style.background='#f7f8fa'" onmouseout="this.style.background='transparent'">Member Management</a>
          </div>
        </div>
      </div>
      <a href="/pricing/" style="font-weight:600;text-decoration:none;color:#0f1115">Pricing</a>
      <a href="/blog/" style="font-weight:600;text-decoration:none;color:#0f1115">Blog</a>
      <a href="/about/" style="font-weight:600;text-decoration:none;color:#0f1115">About</a>
      <a href="https://dash.gripmode.app/login" style="font-weight:600;text-decoration:none;color:#0f1115">Log in</a>
      <a class="btn btn-dark" href="/signup/" style="width:auto;display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:13px 18px;border-radius:12px;background:#111315;color:#fff;text-decoration:none;font-weight:700;border:none">Start Free Trial</a>
