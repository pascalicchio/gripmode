    <!-- Mobile Hamburger -->
    <button class="mobile-toggle" style="display:none;background:none;border:none;cursor:pointer;padding:8px;color:#0f1115" onclick="document.getElementById('mobileMenu').classList.toggle('open')" aria-label="Toggle menu">
      <i data-lucide="menu" style="width:24px;height:24px;color:#0f1115"></i>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobileMenu" class="mobile-menu" style="display:none;background:#fff;border-top:1px solid #e5e7eb;padding:16px 24px">
    <a href="/features/" style="display:block;padding:12px 0;font-weight:600;text-decoration:none;color:#0f1115;border-bottom:1px solid #f0f0f0">Features</a>
    <a href="/pricing/" style="display:block;padding:12px 0;font-weight:600;text-decoration:none;color:#0f1115;border-bottom:1px solid #f0f0f0">Pricing</a>
    <a href="/blog/" style="display:block;padding:12px 0;font-weight:600;text-decoration:none;color:#0f1115;border-bottom:1px solid #f0f0f0">Blog</a>
    <a href="/about/" style="display:block;padding:12px 0;font-weight:600;text-decoration:none;color:#0f1115;border-bottom:1px solid #f0f0f0">About</a>
    <a href="https://dash.gripmode.app/login" style="display:block;padding:12px 0;font-weight:600;text-decoration:none;color:#0f1115;border-bottom:1px solid #f0f0f0">Log in</a>
