    <h1 style="font-size:clamp(2rem,3.8vw,2.8rem);margin-bottom:16px">Best Martial Arts School Management Software in 2026</h1>
    <p style="color:#5f6672;font-size:1.1rem;margin-bottom:32px">{{ metaDesc }}</p>
