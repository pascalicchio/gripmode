---
layout: layout.njk
title: "Page Not Found — Gripmode"
metaDesc: "The page you're looking for doesn't exist. Return to the Gripmode homepage."
permalink: /404.html
---

{% block extraHead %}
<style>
  :root{
    --bg:#ffffff;--bg-soft:#f7f8fa;--text:#0f1115;--muted:#5f6672;--line:#e5e7eb;--black:#111315;--radius:16px;
  }
  .error-page{padding:140px 0 120px;text-align:center;max-width:560px;margin:0 auto}
  .error-code{font-family:"Space Grotesk",sans-serif;font-size:8rem;font-weight:700;line-height:1;color:var(--line);margin-bottom:16px;letter-spacing:-.04em}
  .error-page p{color:var(--muted);font-size:1.1rem;line-height:1.6;margin-bottom:32px}
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:13px 24px;border-radius:12px;border:1px solid transparent;text-decoration:none;font-weight:700;cursor:pointer}
  .btn-dark{background:var(--black);color:#fff}.btn-dark:hover{opacity:.92}
  .btn-light{background:#fff;color:#111;border-color:var(--line)}
</style>
{% endblock %}

<div class="gm-container">
  <div class="error-page">
    <div class="error-code">404</div>
    <h1>Page not found</h1>
    <p>The page you're looking for doesn't exist or has been moved. Let's get you back on track.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a class="btn btn-dark" href="/">Back to Homepage</a>
      <a class="btn btn-light" href="/contact/">Contact Support</a>
    </div>
  </div>
</div>
