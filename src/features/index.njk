---
layout: layout.njk
title: "Features — Gripmode"
metaDesc: "Explore every Gripmode feature: CRM, scheduling, payroll, analytics, member management, inventory, and more — built for martial arts schools."
breadcrumbs:
  - { name: "Home", url: "/" }
  - { name: "Features", url: "/features/" }
---

<!-- Hero -->
<section style="padding:100px 0 60px;background:#fff">
  <div class="gm-container" style="text-align:center;max-width:820px">
    <p style="font-weight:700;text-transform:uppercase;letter-spacing:.12em;font-size:.8rem;color:#5f6672;margin:0 0 16px">Platform</p>
    <h1 style="margin-bottom:20px">Everything You Need to Run Your School</h1>
    <p style="font-size:1.18rem;color:#5f6672;max-width:620px;margin:0 auto 36px;line-height:1.7">One platform for leads, scheduling, payroll, analytics, and operations. No more duct-taping five different tools together.</p>
    <a href="#trial" style="display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:15px 28px;border-radius:12px;background:#111315;color:#fff;text-decoration:none;font-weight:700;font-size:1rem;border:none">Start Free Trial</a>
  </div>
</section>

<!-- Features Grid -->
<section style="padding:40px 0 100px;background:#fff">
  <div class="gm-container">
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px" class="features-grid">
      {% for item in features %}
      <a href="/features/{{ item.slug }}/" style="display:block;text-decoration:none;color:inherit;padding:36px 32px;border:1px solid #e5e7eb;border-radius:16px;transition:border-color .2s,box-shadow .2s" onmouseover="this.style.borderColor='#111315';this.style.boxShadow='0 4px 24px rgba(0,0,0,0.08)'" onmouseout="this.style.borderColor='#e5e7eb';this.style.boxShadow='none'">
        <div style="width:48px;height:48px;background:#f7f8fa;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px">
          <i data-lucide="{{ item.icon }}" style="width:24px;height:24px;color:#0f1115"></i>
        </div>
        <h3 style="font-size:1.2rem;margin-bottom:10px;letter-spacing:-0.01em">{{ item.title }}</h3>
        <p style="color:#5f6672;font-size:.95rem;line-height:1.6;margin:0">{{ item.tagline }}</p>
        <span style="display:inline-flex;align-items:center;gap:6px;margin-top:16px;font-weight:600;font-size:.9rem;color:#0f1115">Learn more <i data-lucide="arrow-right" style="width:16px;height:16px"></i></span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- CTA -->
<section style="padding:80px 0">
  <div class="gm-container">
    <div style="background:#0f1115;color:#fff;border-radius:20px;padding:60px 48px;text-align:center">
      <h2 style="color:#fff;margin-bottom:16px">Ready to see it in action?</h2>
      <p style="color:#c2c7d1;font-size:1.1rem;max-width:540px;margin:0 auto 32px;line-height:1.7">Start your free trial today. No credit card required. Set up your school in under 10 minutes.</p>
      <a href="#trial" style="display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:15px 28px;border-radius:12px;background:#fff;color:#111;text-decoration:none;font-weight:700;font-size:1rem;border:none">Start Free Trial</a>
    </div>
  </div>
</section>

<style>
  @media (max-width: 980px) {
    .features-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 600px) {
    .features-grid { grid-template-columns: 1fr !important; }
  }
</style>
