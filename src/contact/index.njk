---
layout: layout.njk
title: "Contact — Gripmode"
metaDesc: "Get in touch with the Gripmode team. Start your free trial, ask questions, or get support for your martial arts school management."
breadcrumbs:
  - { name: "Home", url: "/" }
  - { name: "Contact", url: "/contact/" }
---

{% block extraHead %}
<style>
  :root{
    --bg:#ffffff;--bg-soft:#f7f8fa;--text:#0f1115;--muted:#5f6672;--line:#e5e7eb;--black:#111315;--radius:16px;--dark-bg:#0f1114;
  }
  section{padding:88px 0}
  .contact-hero{padding:96px 0 48px;max-width:700px}
  .contact-hero .eyebrow{display:inline-flex;align-items:center;gap:8px;padding:7px 12px;border-radius:999px;background:#f4f4f5;border:1px solid var(--line);font-size:.83rem;font-weight:700;margin-bottom:24px}
  .sub{font-size:1.14rem;color:var(--muted);max-width:60ch;line-height:1.7}
  .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
  .contact-info-card{background:var(--bg-soft);border:1px solid var(--line);border-radius:var(--radius);padding:28px;margin-bottom:18px}
  .contact-info-card h3{font-family:"Space Grotesk",sans-serif;font-size:1.15rem;margin-bottom:12px;display:flex;align-items:center;gap:10px}
  .contact-info-card h3 .icon{margin:0;width:20px;height:20px}
  .contact-info-card p{color:var(--muted);font-size:.95rem;margin:0;line-height:1.6}
  .contact-info-card a{color:var(--text);font-weight:600;text-decoration:none}
  .contact-info-card a:hover{text-decoration:underline}
  .contact-cta{background:var(--dark-bg);color:#fff;border-radius:20px;padding:34px}
  .contact-cta h2{color:#fff}
  .contact-cta p{color:#c2c7d1;font-size:1rem;margin-bottom:0}
  @media (max-width:980px){
    section{padding:66px 0}
    .contact-grid{grid-template-columns:1fr}
  }
</style>
{% endblock %}

<div class="gm-container">
  <section class="contact-hero">
    <span class="eyebrow"><i data-lucide="message-circle" style="width:16px;height:16px"></i> We're here to help</span>
    <h1>Get in Touch</h1>
    <p class="sub">Whether you're ready to start your free trial, have questions about Gripmode, or need support -- we'd love to hear from you.</p>
  </section>

  <section style="padding-top:0">
    <div class="contact-grid">
      <div>
        <div class="contact-cta">
          <h2 style="color:#fff;font-size:1.6rem">Start your free trial</h2>
          <p style="color:#c2c7d1;margin-bottom:16px">Submit your school details and we'll send setup instructions within 24 hours.</p>
          {% include "lead-form.njk" %}
        </div>
      </div>
      <div>
        <article class="contact-info-card">
          <h3><i data-lucide="mail" class="icon"></i> Email Support</h3>
          <p>For general questions, technical support, or partnership inquiries.</p>
          <p style="margin-top:10px"><a href="mailto:support@gripmode.app">support@gripmode.app</a></p>
        </article>
        <article class="contact-info-card">
          <h3><i data-lucide="clock" class="icon"></i> Office Hours</h3>
          <p>Our team is available to assist you during business hours.</p>
          <p style="margin-top:10px;color:var(--text);font-weight:600">Monday - Friday: 9:00 AM - 6:00 PM EST</p>
          <p style="margin-top:4px">We typically respond to emails within 4 business hours.</p>
        </article>
        <article class="contact-info-card">
          <h3><i data-lucide="help-circle" class="icon"></i> Quick Answers</h3>
          <p>Check our <a href="/pricing/">pricing page</a> for plan details and feature comparisons, or browse our FAQ for common questions.</p>
        </article>
      </div>
    </div>
  </section>
</div>
